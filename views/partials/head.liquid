<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/stylesheet.css">
    <title>{{ title | default: "PreludeFonds" }}</title>
</head>
<body>
    <header class="navbar">
        <a href="/" class="logo">
            <img src="/icons/logo.svg" alt="PreludeFonds logo">
        </a>
        <nav>
            <ul class="nav-list">
                <li class="{% if menuClass == 'home' %}active{% endif %}">
                    <a href="/">Home</a>
                </li>
                <li class="{% if menuClass == 'overzicht' %}active{% endif %}">
                    <a href="/instruments">Overzicht</a>
                </li>
                <li class="{% if menuClass == 'add' %}active{% endif %}">
                    <a href="/instruments/new">Instrument toevoegen</a>
                </li>
            </ul>
        </nav>
    </header>
    